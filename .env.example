# ──────────────────────────────────────────────────────────────────────────────
# MataData (मतदाता) — Environment Variables
# Copy this file to .env.local and fill in your API keys.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Custom Search API Key (required)
# Used for searching election news and information
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=

# Google Custom Search Engine ID (required)
# Create a Programmable Search Engine at: https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=

# Google Maps API Key (required)
# Used for polling booth location features
# Get yours at: https://console.cloud.google.com/apis/credentials
MAPS_API_KEY=
